generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  CIUDADANO
  ADMIN
}

enum Severidad {
  BAJA
  MEDIA
  ALTA
}

model Usuario {

  id        Int      @id @default(autoincrement())

  nombre    String

  correo    String   @unique

  password  String

  rol       Rol      @default(CIUDADANO)

  reportes  Reporte[]
}

model Reporte {

  id          Int      @id @default(autoincrement())

  titulo      String

  descripcion String

  severidad   Severidad

  fecha       DateTime @default(now())

  usuarioId   Int

  usuario     Usuario @relation(fields:[usuarioId], references:[id])
}